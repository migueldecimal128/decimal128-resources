DEFOP("DECCONTEXTDEFAULT", 0, 0x00400cd0)
DEFOP("DECCONTEXTSETSTATUS", 1, 0x00401508)
DEFOP("DECCONTEXTSETSTATUSFROMSTRING", 2, 0x004010e0)
DEFOP("DECCONTEXTSTATUSTOSTRING", 3, 0x00400eb8)
DEFOP("DECIMAL64FROMNUMBER", 4, 0x0040f800)
DEFOP("DECIMAL64FROMSTRING", 5, 0x004100a0)
DEFOP("DECIMAL64TOENGSTRING", 6, 0x00410030)
DEFOP("DECIMAL64TONUMBER", 7, 0x0040fcd0)
DEFOP("DECIMAL64TOSTRING", 8, 0x0040ffc0)
DEFOP("DECNUMBERABS", 9, 0x00401fe0)
DEFOP("DECNUMBERADD", 10, 0x004020f8)
DEFOP("DECNUMBERCOMPARE", 11, 0x004021a8)
DEFOP("DECNUMBERCOPY", 12, 0x004052e8)
DEFOP("DECNUMBERDIVIDE", 13, 0x00402260)
DEFOP("DECNUMBERDIVIDEINTEGER", 14, 0x00402318)
DEFOP("DECNUMBEREXP", 15, 0x004023d0)
DEFOP("DECNUMBERFROMSTRING", 16, 0x00401640)
DEFOP("DECNUMBERLN", 17, 0x004024c8)
DEFOP("DECNUMBERLOG10", 18, 0x004025c0)
DEFOP("DECNUMBERMAX", 19, 0x00402bc0)
DEFOP("DECNUMBERMIN", 20, 0x00402c78)
DEFOP("DECNUMBERMINUS", 21, 0x00402d30)
DEFOP("DECNUMBERMULTIPLY", 22, 0x00402f48)
DEFOP("DECNUMBERNORMALIZE", 23, 0x00402ff0)
DEFOP("DECNUMBERPLUS", 24, 0x00402e40)
DEFOP("DECNUMBERPOWER", 25, 0x00403160)
DEFOP("DECNUMBERQUANTIZE", 26, 0x00403e48)
DEFOP("DECNUMBERREMAINDER", 27, 0x00403fb0)
DEFOP("DECNUMBERREMAINDERNEAR", 28, 0x00404068)
DEFOP("DECNUMBERRESCALE", 29, 0x00403f00)
DEFOP("DECNUMBERSAMEQUANTUM", 30, 0x00404120)
DEFOP("DECNUMBERSQUAREROOT", 31, 0x00404238)
DEFOP("DECNUMBERSUBTRACT", 32, 0x00404fd8)
DEFOP("DECNUMBERTOENGSTRING", 33, 0x004015e8)
DEFOP("DECNUMBERTOINTEGRALVALUE", 34, 0x00405090)
DEFOP("DECNUMBERTOSTRING", 35, 0x00401590)
DEFOP("DECNUMBERTRIM", 36, 0x004053f0)
DEFOP("DECNUMBERVERSION", 37, 0x00405430)
DEFOP("DECNUMBERZERO", 38, 0x00405448)
DEFOP("EXIT", 39, 0x00411710)
DEFOP("DECARI", 40, 0x0)
