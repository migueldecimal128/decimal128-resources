DEFOP("DECCONTEXTDEFAULT", 0, 0x00412da0)
DEFOP("DECCONTEXTSETSTATUS", 1, 0x004135d8)
DEFOP("DECCONTEXTSETSTATUSFROMSTRING", 2, 0x004131b0)
DEFOP("DECCONTEXTSTATUSTOSTRING", 3, 0x00412f88)
DEFOP("DECIMAL64FROMNUMBER", 4, 0x00411aa0)
DEFOP("DECIMAL64FROMSTRING", 5, 0x00412340)
DEFOP("DECIMAL64TOENGSTRING", 6, 0x004122d0)
DEFOP("DECIMAL64TONUMBER", 7, 0x00411f70)
DEFOP("DECIMAL64TOSTRING", 8, 0x00412260)
DEFOP("DECNUMBERABS", 9, 0x00404280)
DEFOP("DECNUMBERADD", 10, 0x00404398)
DEFOP("DECNUMBERCOMPARE", 11, 0x00404448)
DEFOP("DECNUMBERCOPY", 12, 0x00407588)
DEFOP("DECNUMBERDIVIDE", 13, 0x00404500)
DEFOP("DECNUMBERDIVIDEINTEGER", 14, 0x004045b8)
DEFOP("DECNUMBEREXP", 15, 0x00404670)
DEFOP("DECNUMBERFROMSTRING", 16, 0x004038e0)
DEFOP("DECNUMBERLN", 17, 0x00404768)
DEFOP("DECNUMBERLOG10", 18, 0x00404860)
DEFOP("DECNUMBERMAX", 19, 0x00404e60)
DEFOP("DECNUMBERMIN", 20, 0x00404f18)
DEFOP("DECNUMBERMINUS", 21, 0x00404fd0)
DEFOP("DECNUMBERMULTIPLY", 22, 0x004051e8)
DEFOP("DECNUMBERNORMALIZE", 23, 0x00405290)
DEFOP("DECNUMBERPLUS", 24, 0x004050e0)
DEFOP("DECNUMBERPOWER", 25, 0x00405400)
DEFOP("DECNUMBERQUANTIZE", 26, 0x004060e8)
DEFOP("DECNUMBERREMAINDER", 27, 0x00406250)
DEFOP("DECNUMBERREMAINDERNEAR", 28, 0x00406308)
DEFOP("DECNUMBERRESCALE", 29, 0x004061a0)
DEFOP("DECNUMBERSAMEQUANTUM", 30, 0x004063c0)
DEFOP("DECNUMBERSQUAREROOT", 31, 0x004064d8)
DEFOP("DECNUMBERSUBTRACT", 32, 0x00407278)
DEFOP("DECNUMBERTOENGSTRING", 33, 0x00403888)
DEFOP("DECNUMBERTOINTEGRALVALUE", 34, 0x00407330)
DEFOP("DECNUMBERTOSTRING", 35, 0x00403830)
DEFOP("DECNUMBERTRIM", 36, 0x00407690)
DEFOP("DECNUMBERVERSION", 37, 0x004076d0)
DEFOP("DECNUMBERZERO", 38, 0x004076e8)
DEFOP("EXIT", 39, 0x00414270)
DEFOP("DECARI", 40, 0x0)
