------------------------------------------------------------------------
-- _754_2019.dectest : IEEE 754-2019 hand-written cases                 --
------------------------------------------------------------------------
-- Hand-written cases extracted from the legacy TestDectest* inline     --
-- reproducers (the only non-corpus cases; all other inline cases are   --
-- corpus duplicates). They assert IEEE 754-2019 behaviour where the    --
-- stock pre-2019 dq* files differ:                                     --
--   max/min/maxmag/minmag : maxNumber/minNumber return the number on a --
--                           signaling NaN (raising invalid).           --
--   abs (copyAbs)         : a signaling NaN is NOT quieted.            --
--   minus (negate)        : pure sign flip, NaN/sNaN unquieted.        --
-- The corresponding pre-2019 file cases are vector-filtered            --
-- (RosettaDectestSkips).                                               --
------------------------------------------------------------------------

extended:    1
precision:   34
rounding:    half_even
maxExponent: 6144
minExponent: -6143

-- abs
dqabs523_2019 abs  sNaN    ->  sNaN
dqabs525_2019 abs  sNaN33  ->  sNaN33
dqabs527_2019 abs -sNaN33  ->  sNaN33
dqabs526_2019 abs  -NaN22  ->  NaN22

-- min
dqmin161_2019 min  sNaN -Inf   ->  -Inf  Invalid_operation
dqmin162_2019 min  sNaN -1000  ->  -1000  Invalid_operation
dqmin163_2019 min  sNaN -1     ->  -1  Invalid_operation
dqmin164_2019 min  sNaN -0     ->  -0  Invalid_operation
dqmin165_2019 min -sNaN  0     ->  0  Invalid_operation
dqmin166_2019 min -sNaN  1     ->  1  Invalid_operation
dqmin167_2019 min  sNaN  1000  ->  1000  Invalid_operation
dqmin171_2019 min -Inf  sNaN   ->  -Inf  Invalid_operation
dqmin172_2019 min -1000 sNaN   ->  -1000  Invalid_operation
dqmin173_2019 min -1    sNaN   ->  -1  Invalid_operation
dqmin174_2019 min -0    sNaN   ->  -0  Invalid_operation
dqmin175_2019 min  0    sNaN   ->  0  Invalid_operation
dqmin176_2019 min  1    sNaN   ->  1  Invalid_operation
dqmin177_2019 min  1000 sNaN   ->  1000  Invalid_operation
dqmin178_2019 min  Inf  sNaN   ->  Inf  Invalid_operation
dqmin191_2019 min  sNaN99 -Inf    ->  -Inf Invalid_operation
dqmin192_2019 min  sNaN98 -11     ->  -11 Invalid_operation
dqmin196_2019 min -Inf    sNaN92  ->  -Inf Invalid_operation
dqmin197_2019 min  088    sNaN91  ->  088 Invalid_operation
dqmin198_2019 min  Inf   -sNaN90  ->  Inf Invalid_operation

