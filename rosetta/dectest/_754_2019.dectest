dqmng171_2019 minmag -Inf  sNaN   ->  -Inf  Invalid_operation
dqmng172_2019 minmag -1000 sNaN   ->  -1000  Invalid_operation
dqmng173_2019 minmag -1    sNaN   ->  -1  Invalid_operation
dqmng174_2019 minmag -0    sNaN   ->  -0  Invalid_operation
dqmng175_2019 minmag  0    sNaN   ->  0  Invalid_operation
dqmng176_2019 minmag  1    sNaN   ->  1  Invalid_operation
dqmng177_2019 minmag  1000 sNaN   ->  1000  Invalid_operation
dqmng178_2019 minmag  Inf  sNaN   ->  Inf  Invalid_operation
dqmng191_2019 minmag  sNaN99 -Inf    ->  -Inf Invalid_operation
