-- minus
dqmns021_2019 minus         NaN  -> -NaN
dqmns022_2019 minus        -NaN  ->  NaN
dqmns023_2019 minus        sNaN  -> -sNaN
dqmns024_2019 minus       -sNaN  ->  sNaN
dqmns031_2019 minus       NaN13  -> -NaN13
