dqmxg164_2019 maxmag  sNaN -0     ->  -0  Invalid_operation
dqmxg165_2019 maxmag  sNaN  0     ->  0  Invalid_operation
dqmxg166_2019 maxmag  sNaN  1     ->  1  Invalid_operation
dqmxg167_2019 maxmag  sNaN  1000  ->  1000  Invalid_operation
dqmxg171_2019 maxmag -Inf  sNaN   ->  -Inf  Invalid_operation
dqmxg172_2019 maxmag -1000 sNaN   ->  -1000  Invalid_operation
dqmxg173_2019 maxmag -1    sNaN   ->  -1  Invalid_operation
dqmxg174_2019 maxmag -0    sNaN   ->  -0  Invalid_operation
dqmxg175_2019 maxmag  0    sNaN   ->  0  Invalid_operation
dqmxg176_2019 maxmag  1    sNaN   ->  1  Invalid_operation
dqmxg177_2019 maxmag  1000 sNaN   ->  1000  Invalid_operation
dqmxg178_2019 maxmag  Inf  sNaN   ->  Inf  Invalid_operation
dqmxg191_2019 maxmag  sNaN99 -Inf    ->  -Inf Invalid_operation
dqmxg192_2019 maxmag  sNaN98 -1      ->  -1 Invalid_operation
dqmxg196_2019 maxmag -Inf    sNaN92  ->  -Inf Invalid_operation
dqmxg197_2019 maxmag  0      sNaN91  ->  0 Invalid_operation
dqmxg198_2019 maxmag  Inf   -sNaN90  ->  Inf Invalid_operation

-- max
dqmax161_2019 max  sNaN -Inf   ->  -Inf  Invalid_operation
